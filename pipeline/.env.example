# Credenciales del pipeline de SubeSeguro — COPIAR a pipeline/.env (gitignoreado)
# El .env real NUNCA se commitea.
#
# Gmail de soporte.vetastudios@gmail.com necesita:
#   1. Verificación en 2 pasos activada
#   2. IMAP habilitado (Gmail → Ver todos los ajustes → Reenvío y POP/IMAP)
#   3. Una "Contraseña de aplicación" (myaccount.google.com/apppasswords) → va abajo
IMAP_USER=soporte.vetastudios@gmail.com
IMAP_PASS=xxxx xxxx xxxx xxxx
SMTP_USER=soporte.vetastudios@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Dónde llega el PDF para revisión cuando AUTO_SEND=0
OWNER_EMAIL=daniel.ruben.rojas.vera@gmail.com

# 0 = piloto: el PDF va a OWNER_EMAIL para tu OK antes de mandarlo al cliente.
# 1 = automático: el PDF va directo al cliente. Súbelo a 1 cuando confíes en el motor.
AUTO_SEND=0

# Tope de revisiones gratis por día (protege reputación y costos)
DAILY_LIMIT=10
# Segundos entre pasadas en modo --loop
CHECK_INTERVAL=300
